{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Artisan snack product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Draft", "Archived"] },
        "image": { "type": "string" },
        "isSeasonal": { "type": "boolean" },
        "isBundle": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "stock", "status", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customer": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["New", "In Kitchen", "Packaging", "Shipped", "Cancelled"] },
        "date": { "type": "string", "format": "date-time" },
        "items": { "type": "array" }
      },
      "required": ["customer", "amount", "status", "date", "items"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Snack catalog items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
